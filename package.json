{
  "name": "codex-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Codex workflow modes for product planning, engineering review, shipping, QA, and retrospectives.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-stack": "./dist/cli.js",
    "codex-stack-browse": "./browse/dist/cli.js"
  },
  "scripts": {
    "doctor": "bash scripts/doctor.sh",
    "smoke": "bash scripts/ci-check.sh",
    "review": "node scripts/review-diff.mjs",
    "browse:doctor": "node browse/dist/cli.js doctor",
    "browse:text": "node browse/dist/cli.js text",
    "browse:screenshot": "node browse/dist/cli.js screenshot",
    "build": "node -e \"console.log('Checked-in dist/ is ready. Install TypeScript before enabling a transpile build.')\""
  },
  "dependencies": {
    "playwright": "^1.53.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "codex",
    "skills",
    "workflow",
    "review",
    "ship",
    "qa"
  ]
}
