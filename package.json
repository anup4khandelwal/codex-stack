{
  "name": "codex-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Codex workflow modes for product planning, engineering review, shipping, QA, and retrospectives.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "bin": {
    "codex-stack": "./dist/cli.js",
    "codex-stack-browse": "./browse/dist/cli.js"
  },
  "scripts": {
    "doctor": "bash scripts/doctor.sh",
    "smoke": "bash scripts/ci-check.sh",
    "demo:start": "bun examples/customer-portal-demo/server.mjs",
    "demo:smoke": "bun scripts/demo-smoke.mjs",
    "review": "bun scripts/review-diff.mjs",
    "qa": "bun scripts/qa-run.mjs",
    "ship:dry": "bun scripts/ship-branch.mjs --dry-run",
    "retro": "bun scripts/retro-report.mjs --since '7 days ago'",
    "weekly": "bun scripts/weekly-digest.mjs --since '7 days ago' --no-github",
    "qa:site": "bun scripts/render-qa-pages.mjs --out .site",
    "browse:doctor": "bun browse/dist/cli.js doctor",
    "browse:text": "bun browse/dist/cli.js text",
    "browse:screenshot": "bun browse/dist/cli.js screenshot",
    "build": "bun -e \"console.log('Checked-in dist/ is ready. Install TypeScript before enabling a transpile build.')\""
  },
  "dependencies": {
    "playwright": "^1.53.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "keywords": [
    "codex",
    "skills",
    "workflow",
    "review",
    "ship",
    "qa"
  ]
}
