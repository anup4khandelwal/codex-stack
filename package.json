{
  "name": "codex-stack",
  "version": "0.1.0",
  "private": true,
  "description": "Codex workflow modes for product planning, engineering review, shipping, QA, and retrospectives.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "bin": {
    "codex-stack": "./src/cli.ts",
    "codex-stack-browse": "./browse/src/cli.ts"
  },
  "scripts": {
    "doctor": "bash scripts/doctor.sh",
    "typecheck": "bunx tsc --noEmit",
    "smoke": "bash scripts/ci-check.sh",
    "build": "bun build ./examples/customer-portal-demo/src/app.ts --target browser --format iife --outfile ./examples/customer-portal-demo/public/app.js",
    "demo:start": "bun run build && bun examples/customer-portal-demo/server.ts",
    "demo:smoke": "bun run build && bun scripts/demo-smoke.ts",
    "review": "bun scripts/review-diff.ts",
    "issue": "bun scripts/issue-flow.ts",
    "qa": "bun scripts/qa-run.ts",
    "qa:trends": "bun scripts/qa-trends.ts",
    "preview": "bun scripts/preview-verify.ts",
    "deploy": "bun scripts/deploy-verify.ts",
    "ship:dry": "bun scripts/ship-branch.ts --dry-run",
    "retro": "bun scripts/retro-report.ts --since '7 days ago'",
    "upgrade": "bun scripts/upgrade-check.ts",
    "upgrade:offline": "bun scripts/upgrade-check.ts --offline",
    "upgrade:apply": "bun scripts/upgrade-check.ts --offline --apply",
    "weekly": "bun scripts/weekly-digest.ts --since '7 days ago' --no-github",
    "qa:site": "bun scripts/render-qa-pages.ts --out .site",
    "preview:site": "bun run build && bun scripts/build-preview-site.ts --out .preview-site",
    "browse:doctor": "bun browse/src/cli.ts doctor",
    "browse:text": "bun browse/src/cli.ts text",
    "browse:screenshot": "bun browse/src/cli.ts screenshot"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "keywords": [
    "codex",
    "skills",
    "workflow",
    "review",
    "ship",
    "qa"
  ]
}
