#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOCAL_BIN="$ROOT_DIR/.codex-stack/bin"

write_wrapper() {
  local name="$1"
  local command="$2"
  cat > "$LOCAL_BIN/$name" <<EOF
#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="\$(cd \"\$(dirname \"\$0\")/../..\" && pwd)"
exec node "\$ROOT_DIR/dist/cli.js" $command "\$@"
EOF
  chmod +x "$LOCAL_BIN/$name"
}

echo "[codex-stack] running environment checks"
bash "$ROOT_DIR/scripts/doctor.sh"

if [ "${SKIP_INSTALL:-0}" != "1" ] && [ ! -d "$ROOT_DIR/node_modules/playwright" ]; then
  echo "[codex-stack] installing npm dependencies"
  (
    cd "$ROOT_DIR"
    npm install
  )
fi

mkdir -p "$LOCAL_BIN"
ln -snf "$ROOT_DIR/dist/cli.js" "$LOCAL_BIN/codex-stack"
ln -snf "$ROOT_DIR/browse/dist/cli.js" "$LOCAL_BIN/codex-stack-browse"

write_wrapper "product" "show product"
write_wrapper "tech" "show tech"
write_wrapper "review" "review"
write_wrapper "ship" "ship"
write_wrapper "browse" "browse"
write_wrapper "retro" "retro"

echo "[codex-stack] local wrappers ready:"
echo "  $LOCAL_BIN/codex-stack"
echo "  $LOCAL_BIN/codex-stack-browse"
echo "  $LOCAL_BIN/{product,tech,review,ship,browse,retro}"
echo
echo "Next steps:"
echo "  1. node dist/cli.js list"
echo "  2. use Node 24 for this repo"
echo "  3. npx playwright install chromium"
echo "  4. bash scripts/install-skills.sh user"
echo "  5. node dist/cli.js review"
